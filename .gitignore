# Bundled binaries & models (fetched/placed separately, not versioned)
resources/bin/
# Microsoft VC++ runtime DLLs for Windows onnxruntime
resources/win-vcruntime/

# Speech-recognition model — fetched separately, not versioned (large, and
# not derived from this project's own AGPL-licensed training)
resources/models/*
!resources/models/blade1.onnx
!resources/models/blade2.onnx
!resources/models/blade3.onnx

# Model / weight backups — never commit or ship
*.bak
*.bak_*
*.onnx.bak*

# Build artifacts
*.exe
*.dmg
*.AppImage
*.deb
*.snap

# Archives
source.zip
*.zip

# Video files
*.mp4
