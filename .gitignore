omsni_defs.json

# Test scratch dirs
blade_test/
pose_test/

# Python cache (from blade_measure.py)
__pycache__/
*.pyc

# Real subject media (screenshots, captured images) — keep app assets,
# built-in blade calibration reference photos, and marketing screenshots
# tracked
*.png
*.jpg
*.jpeg
!assets/**
!screenshots/**
!blade_checkerboard.jpeg
!blade_checkerboard2.jpeg
!blade_checkerboard3.jpeg
!docs/screenshot.png

# Electron builder cache
.cache/

# ── Local-only: blade-pose YOLO training material ──────────────────────────
# Training scripts, datasets, and base pretrained checkpoints for rebuilding
# the blade-pose model. Never committed or pushed — stays on this machine
# only. (The *final* exported inference weights — resources/models/blade{1,2,3}.onnx
# — ARE tracked above: they ship inside the built app, so AGPL-3.0 requires
# they be available alongside the source, not just the training pipeline.)
blade_yolo/
*.pt
*.onnx.bak*
